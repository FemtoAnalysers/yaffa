 RowBox[{
  RowBox[{"v1", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r1", " ", 
      RowBox[{"Sin", "[", "theta1", "]"}], " ", 
      RowBox[{"Cos", "[", "phi1", "]"}]}], " ", ",", " ", 
