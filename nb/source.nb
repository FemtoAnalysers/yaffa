Cell[BoxData[{
 RowBox[{
  RowBox[{"J", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{"R", ",", " ", "r"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"exp", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"Transpose", "[", "J", "]"}], ".", 
