Cell[TextData[{
 "Extract the coefficients  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"exp", 
         RowBox[{"(", 
           RowBox[{"-", 
             FractionBox["1", "2"], 
             SuperscriptBox[
              StyleBox["J", "TI"], 
              StyleBox["T", "TI"]], 
             SuperscriptBox[
              RowBox[{"(", 
                RowBox[{
                  SuperscriptBox[
                   StyleBox["T", "TI"], "-"], "1"}], ")"}], 
              StyleBox["T", "TI"]], 
             StyleBox["V", "TI"], 
             SuperscriptBox[
              StyleBox["T", "TI"], "-"], "1", 
             StyleBox["J", "TI"]}], ")"}], "\[LongEqual]", "exp", 
         RowBox[{"(", 
           RowBox[{"-", 
             FractionBox["1", "2"], "\[Alpha]", 
             SuperscriptBox[
              OverscriptBox[
               StyleBox["R", "TI"], "\[RightVector]"], "2"], "+", 
             OverscriptBox[
              StyleBox["R", "TI"], "\[RightVector]"], "\[CenterDot]", 
             OverscriptBox[
              StyleBox["v", "TI"], "\[RightVector]"], "+", 
             StyleBox["C", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\exp(-\\frac {1} {2} J^T (T^-1)^TVT^-1 J) = \\exp(-\\frac {1} {2} \
\\alpha \\vec{R}^2 + \\vec{R}\\cdot \\vec{v} + C)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1f756b17-3c15-41ae-b561-bef8932ce76e"]
}], "Text",
