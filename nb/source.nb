Cell[TextData[{
 "Compute the general source.\nThe infinitesimal volume element is ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", FontSlant -> "Plain"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "12"], 
         StyleBox["d", FontSlant -> "Plain"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "312"], "\[LongEqual]", 
         FractionBox[
          SuperscriptBox[
           StyleBox["M", "TI"], "3"], 
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{
               SubscriptBox["\[Mu]", "12"], 
               SubscriptBox["\[Mu]", "312"]}], ")"}], 
           RowBox[{"3", "/", "2"}]]], 
         SuperscriptBox["\[Rho]", "5"], 
         StyleBox["d", FontSlant -> "Plain"], "\[Rho]", 
         StyleBox["d", FontSlant -> "Plain"], "\[CapitalOmega]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\mathrm{d}\\vec{r}_{12}\\mathrm{d}\\vec{r}_{312}= \
\\frac{M^3}{(\\mu_{12}\\mu_{312})^{3/2}}\\rho^5\\mathrm{d}\\rho\\mathrm{d}\\\
Omega", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "19136586-d9ce-4470-a3ad-87f76ad1ca2c"]
}], "Text",
