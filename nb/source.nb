Cell[TextData[{
 "Perform the change of variables in the exponent:  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"exp", 
         RowBox[{"(", 
           RowBox[{"-", 
             FractionBox["1", "2"], 
             SuperscriptBox[
              StyleBox["X", "TI"], 
              StyleBox["T", "TI"]], 
             StyleBox["V", "TI"], 
             StyleBox["X", "TI"]}], ")"}], "\[LongEqual]", "exp", 
         RowBox[{"(", 
           RowBox[{"-", 
             FractionBox["1", "2"], 
             SuperscriptBox[
              StyleBox["J", "TI"], 
              StyleBox["T", "TI"]], 
             SuperscriptBox[
              RowBox[{"(", 
                RowBox[{
                  SuperscriptBox[
                   StyleBox["T", "TI"], "-"], "1"}], ")"}], 
              StyleBox["T", "TI"]], 
             StyleBox["V", "TI"], 
             SuperscriptBox[
              StyleBox["T", "TI"], "-"], "1", 
             StyleBox["J", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\exp(-\\frac{1}{2} X^TVX ) = \\exp(-\\frac{1}{2} J^T(T^-1)^TVT^-1 J)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "237e85e0-cb5a-4bf1-baf5-bbcbf02f5e0b"]
}], "Text",
