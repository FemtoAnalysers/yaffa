Cell[TextData[{
 "In the  exponent there are 3 terms: 1 quadratic in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        OverscriptBox[
         StyleBox["r", "TI"], "\[RightVector]"], "12"], TraditionalForm], 
     "errors" -> {}, "input" -> "\\vec{r}_{12}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "20025507-8913-4775-9b3f-2a352720274e"],
 ", one quadratic in",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        OverscriptBox[
         StyleBox["r", "TI"], "\[RightVector]"], "312"], TraditionalForm], 
     "errors" -> {}, "input" -> "\\vec{r}_{312}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1997cdc6-dcfb-4e30-895d-cb9f245c540d"],
 " and one that depends on the scalar product ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "12"], "\[CenterDot]", 
         SubscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "312"]}], TraditionalForm],
      "errors" -> {}, "input" -> "\\vec{r}_{12}\\cdot \\vec{r}_{312}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4f31883b-0bbe-454e-b483-709b2108d0a0"],
 ".\nFrom the definitions of the hyperspherical coordinates:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "12", "2"], "\[LongEqual]", 
         SqrtBox[
          FractionBox[
           StyleBox["M", "TI"], 
           SubscriptBox["\[Mu]", "12"]]], "\[Rho]", "cos", "\[CurlyPhi]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\vec{r}_{12}^2 =\\sqrt{\\frac{M}{\\mu_{12}}}\\rho\\cos\\varphi", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "18f4eed3-e201-4b64-839b-ef4cf203c9bc"],
 "\nand\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          OverscriptBox[
           StyleBox["r", "TI"], "\[RightVector]"], "312", "2"], 
         "\[LongEqual]", 
         SqrtBox[
          FractionBox[
           StyleBox["M", "TI"], 
           SubscriptBox["\[Mu]", "312"]]], "\[Rho]", "sin", "\[CurlyPhi]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\vec{r}_{312}^2 =\\sqrt{\\frac{M}{\\mu_{312}}}\\rho\\sin\\varphi", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e7257ca0-527c-46ce-981c-04e8b3a35b27"],
 "\nTo compute the scalar product in spherical coordinates define ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["v", "TI"], "1"], TraditionalForm], "errors" -> {}, "input" -> 
     "v_1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "555c5bb9-7fa4-4d05-83b4-40aa24bc9e23"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["v", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "v_2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b949cd73-e45c-40cb-9405-6289cc3fbeaa"]
}], "Text",
 CellChangeTimes->{{3.976962490265831*^9, 3.976962610097748*^9}, {
  3.976962671412878*^9, 3.976962767758485*^9}, {3.9769628018217707`*^9, 
  3.9769628765194483`*^9}, {3.976962959453013*^9, 3.97696298886248*^9}, {
  3.977200362392536*^9, 
  3.97720036584109*^9}},ExpressionUUID->"36a63c2c-d3d9-413e-a686-\
ac3ac2045f73"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"v1", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r1", " ", 
      RowBox[{"Sin", "[", "theta1", "]"}], " ", 
      RowBox[{"Cos", "[", "phi1", "]"}]}], " ", ",", " ", 
     RowBox[{"r1", " ", 
      RowBox[{"Sin", "[", "theta1", "]"}], 
      RowBox[{"Sin", "[", "phi1", "]"}]}], " ", ",", " ", 
     RowBox[{"r1", " ", 
      RowBox[{"Cos", "[", "theta1", "]"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"v2", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r2", " ", 
      RowBox[{"Sin", "[", "theta2", "]"}], " ", 
      RowBox[{"Cos", "[", "phi2", "]"}]}], " ", ",", " ", 
     RowBox[{"r2", " ", 
      RowBox[{"Sin", "[", "theta2", "]"}], 
      RowBox[{"Sin", "[", "phi2", "]"}]}], " ", ",", " ", 
     RowBox[{"r2", " ", 
      RowBox[{"Cos", "[", "theta2", "]"}]}]}], "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.976962578963296*^9, 3.9769625795002413`*^9}, {
  3.976962992076185*^9, 3.9769631716902122`*^9}, {3.976963310518784*^9, 
  3.97696332357688*^9}, {3.976963363656993*^9, 3.9769634934931717`*^9}},
 CellLabel->
  "In[575]:=",ExpressionUUID->"f236e3e2-9201-4184-ae16-c406f24e7f09"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
