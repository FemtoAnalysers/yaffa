from rich.console import Console
from rich.layout import Layout
from rich.live import Live
from time import sleep
from rich.panel import Panel
from rich.text import Text
import os
import sys
import subprocess

from rich import print
from rich.layout import Layout

layout = Layout()

with Live(layout, screen=True):
    while True:
        sleep(1)
        ya = os.environ["YAFFA"]
        proc = subprocess.run(['whois', 'ge86rim'], stdout=subprocess.PIPE).stdout.decode('utf-8')
        
        layout.split_row(
            Layout(Panel(Text("Batchfarm status" + ya +  proc, justify="center"))),
            Layout(name="lower")
        )
        print(layout)

